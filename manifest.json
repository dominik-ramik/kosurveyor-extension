{
  "manifest_version": 3,
  "name": "KoSurveyor proxy",
  "version": "1.0.1",
  "description": "Proxies KoboToolbox API requests through the extension to bypass CORS. Configurable Kobo server URL.",

  "permissions": [
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "https://kf.kobotoolbox.org/*",
    "http://localhost/*",
    "https://localhost/*",
    "https://kosurveyor.netlify.app/*" 
  ],

  "optional_host_permissions": [
    "https://*/*"
  ],

  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "https://localhost/*",
        "https://kosurveyor.netlify.app/*"
      ],
      "js": ["content-isolated.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "http://localhost/*",
        "https://localhost/*",
        "https://kosurveyor.netlify.app/*"
      ],
      "js": ["content-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}